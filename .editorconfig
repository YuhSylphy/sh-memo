root = true

[*.{js,jsx,ts,tsx,css,md}]
charset = utf-8
end_of_line = lf
indent_style = tab
indent_size = 4
tab_width = 4
insert_final_newline = true
trim_trailing_whitespace = true

[package.json]
indent_style = space
indent_size = 2

[tsconfig*.json]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false